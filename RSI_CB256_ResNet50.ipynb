])

plt.title("Loss")

plt.show()
```

---

# Step 11: Predictions


y_pred_prob = model.predict(X_test)

y_pred = np.argmax(
    y_pred_prob,
    axis=1
)

y_true = np.argmax(
    y_test,
    axis=1
)
```

---

# Step 12: Classification Report

print(
    classification_report(
        y_true,
        y_pred
    )
)
```

---

# Step 13: Confusion Matrix


import seaborn as sns

cm = confusion_matrix(
    y_true,
    y_pred
)

plt.figure(figsize=(10,8))

sns.heatmap(
    cm,
    cmap='Blues'
)

plt.show()
```

---

# Step 14: Calculate Metrics

accuracy = accuracy_score(y_true,y_pred)

precision = precision_score(
    y_true,
    y_pred,
    average='weighted'
)

recall = recall_score(
    y_true,
    y_pred,
    average='weighted'
)

f1 = f1_score(
    y_true,
    y_pred,
    average='weighted'
)

kappa = cohen_kappa_score(
    y_true,
    y_pred
)

mcc = matthews_corrcoef(
    y_true,
    y_pred
)

print("Accuracy =",accuracy)
print("Precision =",precision)
print("Recall =",recall)
print("F1 =",f1)
print("Kappa =",kappa)
print("MCC =",mcc)
```

